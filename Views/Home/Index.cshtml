@model TPI_GESTION_HOGAR.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="text-primary fw-bold"><i class="bi bi-house-heart-fill"></i> Panel de Control - Hogar </h2>
    <div class="text-muted fw-bold">
        <i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd/MM/yyyy")
    </div>
</div>

<div class="row mb-4 gy-3">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 border-start border-primary border-4 h-100">
            <div class="card-body">
                <h6 class="text-muted fw-bold text-uppercase mb-2">Total Alojados</h6>
                <div class="d-flex align-items-center">
                    <div class="display-5 fw-bold text-primary me-3">
                        @(Model.TotalMujeres + Model.TotalMenores)
                    </div>
                    <div>
                        <div class="text-muted"><i class="bi bi-person-fill"></i> @Model.TotalMujeres Mujeres</div>
                        <div class="text-muted"><i class="bi bi-people-fill"></i> @Model.TotalMenores Menores</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 border-start border-success border-4 h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h6 class="text-muted fw-bold text-uppercase mb-2">Habitaciones</h6>
                    <div class="d-flex align-items-center mb-3">
                        <div class="display-5 fw-bold text-success me-3">
                            @Model.HabitacionesOcupadas <span class="fs-4 text-muted">/ @Model.HabitacionesTotales</span>
                        </div>
                        <div class="text-muted">
                            Ocupadas actualmente
                        </div>
                    </div>
                </div>
                <a asp-controller="Habitaciones" asp-action="Index" class="btn btn-sm btn-outline-success w-100 fw-bold">
                    <i class="bi bi-grid-fill"></i> Ver Mapa de Habitaciones
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 border-start border-warning border-4 h-100 bg-light">
            <div class="card-body">
                <h6 class="text-muted fw-bold text-uppercase mb-2"><i class="bi bi-shield-check"></i> Guardia Activa</h6>

                @if (Model.OperadorasTurnoActual != null && Model.OperadorasTurnoActual.Any())
                {
                    foreach (var turno in Model.OperadorasTurnoActual)
                    {
                        <div class="d-flex align-items-start mb-3 bg-white p-2 rounded border shadow-sm">
                            <i class="bi bi-person-badge fs-2 text-warning me-3 mt-1"></i>
                            <div>
                                <span class="badge bg-warning text-dark mb-1">Turno @(turno.TipoTurno?.Descripcion)</span>
                            
                                <div class="fw-bold text-dark">
                                    <i class="bi bi-person-fill text-primary"></i> @(turno.Personal?.Apellido), @(turno.Personal?.Nombre)
                                </div>
                            
                                @if (turno.PersonalOpc != null)
                                {
                                    <div class="fw-bold text-secondary mt-1" style="font-size: 0.9rem;">
                                        <i class="bi bi-person-plus-fill text-info"></i> @(turno.PersonalOpc?.Apellido), @(turno.PersonalOpc?.Nombre) <span class="badge bg-light text-muted border">Apoyo</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="d-flex align-items-center mb-2 bg-white p-2 rounded border border-danger shadow-sm">
                        <i class="bi bi-exclamation-triangle fs-3 text-danger me-2"></i>
                        <div>
                            <span class="badge bg-danger">Sin Cobertura</span>
                            <div class="fw-bold text-danger">Guardia descubierta</div>
                        </div>
                    </div>
                }

                @if (Model.OperadorasTurnoSiguiente != null && Model.OperadorasTurnoSiguiente.Any())
                {
                    var proximoTurno = Model.OperadorasTurnoSiguiente.First();
                    <div class="text-muted small mt-2 border-top pt-2">
                        <i class="bi bi-arrow-right-short fs-5 text-primary"></i> Próximo Relevo:
                        <strong>@(proximoTurno.Personal?.Apellido)</strong>
                    
                        @if (proximoTurno.PersonalOpc != null)
                        {
                            <span> y <strong>@(proximoTurno.PersonalOpc?.Apellido)</strong></span>
                        }
                        <span class="text-secondary">(@(proximoTurno.TipoTurno?.Descripcion))</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mb-4 gy-3">
    <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100 border-danger">
                <div class="card-header bg-danger text-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-bell-fill"></i> Alertas y Tareas Pendientes</span>
                    <button type="button" class="btn btn-sm btn-light text-danger fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNuevoRecordatorio">
                        <i class="bi bi-plus-lg"></i> Agregar Tarea
                    </button>
                </div>
                <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                    @if (Model.RecordatoriosActivos != null && Model.RecordatoriosActivos.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var rec in Model.RecordatoriosActivos)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center @(rec.Importante ? "bg-danger bg-opacity-10 border-start border-danger border-4" : "")">
                                    <div>
                                        <h6 class="mb-1 fw-bold @(rec.Importante ? "text-danger" : "text-dark")">
                                            @rec.Descripcion
                                        </h6>
                                        <small class="text-muted">
                                            <i class="bi bi-clock"></i> Vence: @rec.FechaLimite.ToString("dd/MM HH:mm") | <i class="bi bi-person"></i> @(rec.Personal?.Apellido)
                                        </small>
                                    </div>
                                <form asp-controller="Recordatorios" asp-action="MarcarResuelto" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@rec.Id" />
                                    <button type="button" class="btn btn-outline-success btn-sm rounded-circle shadow-sm btn-resolver"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalResolverRecordatorio"
                                            data-id="@rec.Id"
                                            data-desc="@rec.Descripcion"
                                            title="Resolver Tarea">
                                        <i class="bi bi-check-lg fw-bold"></i>
                                    </button>
                                </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-4 text-muted">
                            <i class="bi bi-check2-circle fs-1 d-block mb-2 text-success"></i>
                            <p class="mb-0 fw-bold">No hay alertas ni tareas pendientes.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 border-info bg-info bg-opacity-10">
                <div class="card-body text-center d-flex flex-column justify-content-center p-4">
                    <i class="bi bi-journal-bookmark-fill display-4 text-info mb-3"></i>
                    <h5 class="fw-bold text-dark mb-3">Libro de Novedades</h5>
                    <p class="text-muted small mb-4">Acceda al registro completo de pases de guardia y reportes de operadoras.</p>
                    <a asp-controller="Novedades" asp-action="Index" class="btn btn-info text-white fw-bold shadow-sm btn-lg w-100">
                        <i class="bi bi-book"></i> Abrir Libro
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalNuevoRecordatorio" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-bell-plus"></i> Nueva Alerta</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            <form asp-controller="Recordatorios" asp-action="CrearDesdeDashboard" method="post">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Descripción de la Tarea</label>
                            <input type="text" name="Descripcion" class="form-control border-danger" placeholder="Ej: Acompañar a UFI N°2, Dar medicación..." required />
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">Fecha Límite</label>
                                <input type="datetime-local" name="FechaLimite" class="form-control" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">¿Asignada por?</label>
                                <select name="PersonalId" class="form-select" asp-items="@ViewBag.PersonalActivo" required>
                                    <option value="">-- Operadora --</option>
                                </select>
                            </div>
                        </div>
                    <div class="mb-3 p-3 bg-light rounded border">
                        <label class="form-label fw-bold text-primary"><i class="bi bi-person-bounding-box"></i> Vincular a Residente (Opcional)</label>
                        <select name="RegistroId" class="form-select border-primary" asp-items="@ViewBag.ResidentesActivas">
                            <option value="">-- Alerta General del Hogar --</option>
                        </select>
                        <small class="text-muted">Si selecciona una residente, esta alerta y su resultado quedarán en su legajo.</small>
                    </div>
                        <div class="form-check form-switch mt-3 fs-6">
                            <input class="form-check-input" type="checkbox" name="Importante" value="true">
                            <label class="form-check-label text-danger fw-bold">Marcar como Urgente / Importante</label>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger fw-bold px-4"><i class="bi bi-save"></i> Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
        <span><i class="bi bi-list-ul"></i> Residentes Actuales</span>
        <a asp-controller="Mujeres" asp-action="VerificarDni" class="btn btn-sm btn-primary border-0 shadow-sm">
            <i class="bi bi-plus-circle"></i> Nuevo Ingreso
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th class="d-none d-md-table-cell">Fecha de Ingreso</th>
                        <th>Residente</th>
                        <th class="d-none d-md-table-cell">Menores a Cargo</th>
                        <th>Habitación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.IngresosActivos != null && Model.IngresosActivos.Any())
                    {
                        foreach (var item in Model.IngresosActivos)
                        {
                            <tr>
                                <td class="fw-bold text-secondary d-none d-md-table-cell">@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td class="text-start fw-bold text-primary">@(item.Mujer?.Apellido), @(item.Mujer?.Nombre)</td>
                                <td class="d-none d-md-table-cell"><span class="badge bg-info text-dark">@(item.Mujer?.Hijos?.Count ?? 0)</span></td>
                                <td>
                                    @if (item.Habitacion != null)
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-door-closed"></i> Hab. @item.Habitacion.NroHabitacion</span>
                                    }
                                    else
                                    {
                                        <a asp-controller="Registros" asp-action="AsignarHabitacion" asp-route-id="@item.Id" class="badge bg-danger text-white text-decoration-none">
                                            <i class="bi bi-exclamation-triangle"></i> Asignar Cama
                                        </a>
                                    }
                                </td>
                              
                                <td class="text-nowrap">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-controller="Registros" asp-action="Detalles" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold" title="Ver Ficha Técnica">
                                            Ver Ficha
                                        </a>

                                        <button type="button" class="btn btn-sm btn-warning fw-bold text-dark btn-novedad"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalNovedadRapida"
                                                data-id="@item.Id"
                                                data-nombre="@item.Mujer.Apellido, @item.Mujer.Nombre"
                                                title="Cargar Novedad / Seguimiento">
                                            <i class="bi bi-pencil-square"></i> Nota
                                        </button>

                                        <a asp-controller="Egresos" asp-action="Crear" asp-route-registroId="@item.Id" class="btn btn-sm btn-danger fw-bold" title="Registrar Egreso">
                                            <i class="bi bi-box-arrow-right"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="p-4 text-muted">No hay ingresos activos.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNuevaNovedad" tabindex="-1" aria-labelledby="modalNovedadLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title fw-bold" id="modalNovedadLabel"><i class="bi bi-pencil-square"></i> Escribir en el Libro</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Novedades" asp-action="CrearDesdeDashboard" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">¿Quién firma la novedad?</label>
                        <select name="PersonalId" class="form-select border-info" asp-items="@ViewBag.PersonalActivo" required>
                            <option value="">-- Seleccione su nombre --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Novedad / Mensaje</label>
                        <textarea name="Descripcion" class="form-control border-info" rows="4" placeholder="Escriba aquí los detalles del turno..." required></textarea>
                    </div>
                    <div class="form-check form-switch mt-4 fs-6 bg-light p-3 rounded border border-info border-opacity-25">
                        <input class="form-check-input ms-1 me-2" type="checkbox" name="EsPaseDeGuardia" value="true" id="checkPaseGuardia">
                        <label class="form-check-label text-info fw-bold" for="checkPaseGuardia">
                            Marcar como "Pase de Guardia" (Cierre de turno)
                        </label>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info text-white fw-bold px-4"><i class="bi bi-send"></i> Publicar Novedad</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalResolverRecordatorio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-check2-circle"></i> Resolver Tarea</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Recordatorios" asp-action="MarcarResuelto" method="post">
                <input type="hidden" name="id" id="resolverRecordatorioId" value="" />

                <div class="modal-body p-4">
                    <p class="text-muted mb-3 small">Tarea seleccionada: <br /><strong id="resolverRecordatorioDesc" class="text-dark fs-6"></strong></p>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-success">¿Quién resolvió esta tarea?</label>
                        <select name="personalId" class="form-select border-success" asp-items="@ViewBag.PersonalActivo" required>
                            <option value="">-- Operadora / Profesional --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-success">Resultado / Observaciones</label>
                        <textarea name="observacion" class="form-control border-success" rows="3" placeholder="Ej: Se la acompañó al juzgado, se presentó el escrito..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success fw-bold px-4"><i class="bi bi-check-lg"></i> Guardar y Cerrar Alerta</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="modalNovedadRapida" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-journal-text"></i> Cargar Novedad Diaria</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-controller="Seguimientos" asp-action="CargaRapida" method="post" enctype="multipart/form-data">
                <input type="hidden" name="registroId" id="novedadRegistroId" value="" />

                <div class="modal-body p-4">
                    <p class="text-muted mb-3 small">Residente: <strong id="novedadNombreResidente" class="text-dark fs-6"></strong></p>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small">Categoría</label>
                            <select name="categoria" class="form-select border-warning" required>
                                <option value="Convivencia">Convivencia</option>
                                <option value="Salud">Salud / Médico</option>
                                <option value="Legal">Legal / Juzgado</option>
                                <option value="Psicología">Psicología</option>
                                <option value="Trabajo Social">Trabajo Social</option>
                                <option value="General" selected>General / Guardia</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small">Firma Operadora</label>
                            <select name="personalId" class="form-select border-warning" asp-items="@ViewBag.PersonalActivo" required>
                                <option value="">-- Seleccione --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Desarrollo de la novedad</label>
                        <textarea name="descripcion" class="form-control border-warning shadow-sm" rows="4" placeholder="Describa lo sucedido..." required></textarea>
                    </div>

                    <div class="mb-3 border-top border-warning pt-3 mt-3">
                        <label class="form-label fw-bold small text-secondary"><i class="bi bi-paperclip"></i> Adjuntar Documento (Opcional)</label>
    
                        <div class="row">
                            <div class="col-md-5 mb-2">
                                <select name="tipoDocumento" class="form-select form-select-sm border-warning">
                                    <option value="Otro">-- Otro --</option>
                                    <option value="DNI / Identidad">DNI / Identidad</option>
                                    <option value="Receta Médica">Receta Médica</option>
                                    <option value="Estudio Médico">Estudio Médico</option>
                                    <option value="Oficio Judicial">Oficio Judicial</option>
                                    <option value="Denuncia Policial">Denuncia Policial</option>
                                    <option value="Informe Profesional">Informe Profesional</option>
                                    <option value="Alta / Baja">Alta / Baja</option>
                                </select>
                            </div>
                            <div class="col-md-7">
                                <input type="file" name="archivoAdjunto" class="form-control form-control-sm border-warning" accept=".jpg,.jpeg,.png,.pdf" />
                            </div>
                        </div>
                        <small class="text-muted" style="font-size: 0.75rem;">Si adjunta un archivo, por favor indique qué tipo de documento es en el menú de al lado.</small>
                    </div>

                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning fw-bold text-dark px-4"><i class="bi bi-save"></i> Guardar en Legajo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            
            $('.btn-resolver').click(function () {
               
                var idAlerta = $(this).data('id');
                var descripcion = $(this).data('desc');

              
                $('#resolverRecordatorioId').val(idAlerta);
                $('#resolverRecordatorioDesc').text(descripcion);
            });
                  
        $('.btn-novedad').click(function () {
            $('#novedadRegistroId').val($(this).data('id'));
            $('#novedadNombreResidente').text($(this).data('nombre'));
        });

        });
    </script>
}