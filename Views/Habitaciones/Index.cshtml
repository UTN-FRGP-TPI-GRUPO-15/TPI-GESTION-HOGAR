@model IEnumerable<TPI_GESTION_HOGAR.Models.Habitacion>


@{
    ViewData["Title"] = "Gestión de Habitaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary"><i class="bi bi-door-open-fill"></i> Habitaciones del Hogar</h2>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var hab in Model)
    {
        // 1. Lógica de cálculo (ahora cuenta a la mujer + sus hijos)
        int personasAlojadas = hab.Registros.Sum(r => 1 + (r.Mujer?.Hijos?.Count ?? 0));

        // 2. Lógica de Bloqueo (Si hay al menos 1 registro, la pieza se bloquea completa)
        bool estaBloqueada = hab.Registros.Any();

        <div class="col">
            <div class="card h-100 shadow-sm border-0 @(hab.Estado ? (estaBloqueada ? "border-danger" : "border-success") : "border-secondary") border-top border-4">
                <div class="card-body text-center">

                    <h3 class="card-title fw-bold @(hab.Estado ? (estaBloqueada ? "text-danger" : "text-success") : "text-secondary")">
                        <i class="bi @(hab.Estado ? (estaBloqueada ? "bi-door-closed-fill" : "bi-door-open") : "bi-tools")"></i>
                        Habitación @hab.NroHabitacion
                    </h3>

                    @if (!hab.Estado)
                    {
                        <span class="badge bg-secondary mb-3 fs-6">En Mantenimiento</span>
                        <p class="text-muted small">No disponible para asignación.</p>
                    }
                    else if (estaBloqueada)
                    {
                        <span class="badge bg-danger mb-3 fs-6"><i class="bi bi-lock-fill"></i> Ocupada (Exclusiva)</span>

                        <div class="bg-light p-2 rounded mb-3 border border-danger border-opacity-25">
                            <p class="mb-1 fw-bold text-dark">Familia Alojada:</p>
                            @foreach (var reg in hab.Registros)
                            {
                                <p class="mb-0 text-primary fw-bold">@reg.Mujer?.Apellido, @reg.Mujer?.Nombre</p>
                                <small class="text-muted"><i class="bi bi-people-fill"></i> con @(reg.Mujer?.Hijos?.Count ?? 0) menor/es</small>
                            }
                        </div>

                        <div class="d-flex justify-content-between text-muted small fw-bold mt-3">
                            <span>Ocupación Física:</span>
                            <span>@personasAlojadas / @hab.Capacidad plazas</span>
                        </div>
                        <div class="progress mt-1" style="height: 8px;">
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @((personasAlojadas * 100) / hab.Capacidad)%"></div>
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-success mb-3 fs-6"><i class="bi bi-check-circle-fill"></i> Disponible</span>

                        <p class="text-muted mt-3 mb-4">
                            Capacidad para alojar un grupo familiar de hasta <strong>@hab.Capacidad personas</strong>.
                        </p>

                        <div class="d-flex justify-content-between text-muted small fw-bold">
                            <span>Plazas libres:</span>
                            <span class="text-success">@hab.Capacidad plazas</span>
                        </div>
                        <div class="progress mt-1" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-white border-top-0 p-3 text-center d-grid gap-2">
                    @if (hab.Estado && !estaBloqueada)
                    {
                        <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-sm fw-bold">
                            <i class="bi bi-box-arrow-in-right"></i> Asignar Ingreso
                        </a>
                    }
                    else if (hab.Estado && estaBloqueada)
                    {
                        <a asp-controller="Registros" asp-action="Detalles" asp-route-id="@hab.Registros.First().Id" class="btn btn-outline-danger btn-sm fw-bold">
                            <i class="bi bi-folder2-open"></i> Ver Expediente
                        </a>
                    }
                    <a asp-action="Editar" asp-route-id="@hab.Id" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-pencil"></i> Modificar Estado
                    </a>
                </div>
            </div>
        </div>

        
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-controller="Home" asp-action="Index" asp-route-id="@ViewBag.RegistroId" class="btn btn-outline-secondary shadow-sm">
        <i class="bi bi-arrow-"></i> Volver
    </a>
    </div>
</div>