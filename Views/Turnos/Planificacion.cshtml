@using System.Globalization
@using TPI_GESTION_HOGAR.DTOs
@{
    ViewData["Title"] = "Planificación";
}

@{
    var turnos = (List<NuevoTurnoDTO>)ViewBag.Turnos;
    var personal = (List<Personal>)ViewBag.Operadores;
    var tipoTurnos = (List<TipoTurno>)ViewBag.TipoTurnos;

    DateOnly inicioSemana = (DateOnly)ViewBag.InicioSemana;
    DateOnly hoy = DateOnly.FromDateTime(DateTime.Today);
    bool semanaEditable = inicioSemana.AddDays(6) >= hoy;
}

<div class="card shadow-sm border-0">

    <div class="card-body">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <h3 class="fw-bold mb-1">Planificación Semanal</h3>
                <div class="text-muted">
                    Semana del @inicioSemana.ToString("dd/MM/yyyy")
                    al @inicioSemana.AddDays(6).ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="btn-group">
                <a class="btn btn-outline-secondary"
                       asp-action="Planificacion"
                       asp-route-fecha="@inicioSemana.AddDays(-7).ToString("yyyy-MM-dd")">
                    <i class="bi bi-arrow-left"></i>
                </a>

                <a class="btn btn-outline-primary"
                       asp-action="Planificacion"
                       asp-route-fecha="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")">
                    Hoy
                </a>

                <a class="btn btn-outline-secondary"
                       asp-action="Planificacion"
                       asp-route-fecha="@inicioSemana.AddDays(7).ToString("yyyy-MM-dd")">
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>

        <form asp-action="GuardarPlanificacion" method="post">
            @{
                int contador = 0;
            }

            <input type="hidden" name="fecha" value="@inicioSemana.ToString("yyyy-MM-dd")" />

            <div class="table-responsive">
                <table class="table align-middle table-hover">

                    <thead class="table-light">
                        <tr>
                            <th style="min-width:150px;">Día</th>

                            @foreach (var tipo in tipoTurnos)
                            {
                                <th class="text-center">@tipo.Descripcion</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < 7; i++)
                        {
                            var fecha = inicioSemana.AddDays(i);

                            <tr>
                                <td class="fw-semibold">
                                    @fecha.ToString("dddd dd/MM", new CultureInfo("es-ES"))
                                </td>

                                @foreach (var tipo in tipoTurnos)
                                {
                                    var turno = turnos.FirstOrDefault(t =>
                                        t.Fecha == fecha &&
                                        t.TipoTurnoId == tipo.Id);

                                    bool esPasado = fecha < hoy;

                                    <td class="@(turno?.PersonalId == null ? "bg-warning-subtle" : "")">

                                        <div class="d-flex flex-column gap-1">

                                            <input type="hidden" name="turnos[@contador].Fecha" value="@fecha" />
                                            <input type="hidden" name="turnos[@contador].TipoTurnoId" value="@tipo.Id" />

                                            <select name="turnos[@contador].PersonalId"
                                                    class="form-select form-select-sm personal-principal"
                                                    data-index="@contador"
                                                    @(esPasado ? "disabled" : "")>

                                                <option value="">Principal</option>

                                                @foreach (var p in personal)
                                                {
                                                    <option value="@p.Id" selected="@(turno?.PersonalId == p.Id)">
                                                        @p.Nombre @p.Apellido
                                                    </option>
                                                }

                                            </select>

                                            <select name="turnos[@contador].PersonalOpcId"
                                                    class="form-select form-select-sm personal-opcional"
                                                    data-index="@contador"
                                                    data-pasado="@esPasado"
                                                @(turno?.PersonalId == null || esPasado ? "disabled" : "")>

                                                <option value="">Opcional</option>

                                                @foreach (var p in personal)
                                                {
                                                    <option value="@p.Id" selected="@(turno?.PersonalOpcId == p.Id)">
                                                        @p.Nombre @p.Apellido
                                                    </option>
                                                }

                                            </select>

                                        </div>

                                    </td>

                                    contador++;
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (semanaEditable) {
                <div class="d-flex justify-content-end mt-3 gap-2">
                    <button type="button" id="limpiarSemana" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i> Limpiar Semana
                    </button>
                    <a class="btn btn-outline-secondary" asp-action="Planificacion" asp-route-fecha="@inicioSemana.ToString("yyyy-MM-dd")">
                        <i class="bi bi-arrow-counterclockwise"></i> Restablecer
                    </a>
                    <a class="btn btn-success" asp-action="Planificacion" 
                        asp-route-fecha="@inicioSemana.ToString("yyyy-MM-dd")" 
                        asp-route-repetir="true">
                        <i class="bi bi-repeat"></i> Repetir
                    </a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                </div>
            }

        </form>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const principales = document.querySelectorAll(".personal-principal");

        principales.forEach(principal => {
            principal.addEventListener("change", function () {
                const index = this.dataset.index;
                const opcional = document.querySelector(`.personal-opcional[data-index="${index}"]`);

                Array.from(opcional.options).forEach(opt => opt.disabled = false);

                if (!this.value) {
                    opcional.value = "";
                    opcional.disabled = true;
                    return
                }

                const esPasado = opcional.dataset.pasado === "True";
                if (esPasado) {
                    opcional.disabled = true;
                    return;
                }

                opcional.disabled = false;

                const opcionIgual = opcional.querySelector(`option[value="${this.value}"]`);
                if (opcionIgual) {
                    opcionIgual.disabled = true;
                }

                if (opcional.value === this.value) {
                    opcional.value = "";
                }
            });
        });

        const btnLimpiar = document.getElementById("limpiarSemana");

        btnLimpiar.addEventListener("click", function () {
            const principales = document.querySelectorAll(".personal-principal");

            principales.forEach(p => {
                p.value = "";
                p.dispatchEvent(new Event("change"));
            });
        });

        //Forzar el cambio para aplicar las reglas al cargar la página
        principales.forEach(p => p.dispatchEvent(new Event("change")));
    });

</script>