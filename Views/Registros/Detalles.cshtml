@model TPI_GESTION_HOGAR.Models.Registro

@{
    ViewData["Title"] = "Ficha de Ingreso";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2 border-bottom pb-3">
    <div>
        <h2 class="text-primary fw-bold mb-0">
            <i class="bi bi-folder2-open"></i> Expediente de Ingreso N° @Model.Id
        </h2>
        <span class="text-muted">Ingresada el @Model.Fecha.ToString("dd/MM/yyyy")</span>
    </div>
    
    
    <div class="d-flex align-items-center gap-2">
        
        
        @if (Model.Estado == true)
        {
            <a asp-controller="Egresos" asp-action="Crear" asp-route-registroId="@Model.Id" class="btn btn-danger fw-bold shadow-sm">
                <i class="bi bi-box-arrow-right"></i> Registrar Egreso
            </a>
        }
        else
        {
            <span class="badge bg-secondary p-2 px-3 shadow-sm border fs-6">
                <i class="bi bi-door-closed-fill"></i> Expediente Cerrado
            </span>
        }

        <a asp-controller="Registros" asp-action="Legajo" asp-route-id="@Model.Id" class="btn btn-warning fw-bold text-dark shadow-sm">
            <i class="bi bi-journal-text"></i> Historial / Seguimiento
        </a>
        
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">

        <div class="card shadow-sm border-0 border-top border-primary border-4 mb-4">
            <div class="card-body">
                <h5 class="card-title text-primary fw-bold"><i class="bi bi-person-fill"></i> Datos de la Residente</h5>
                <hr />
                <h4 class="fw-bold">@Model.Mujer?.Apellido, @Model.Mujer?.Nombre</h4>
                <p class="mb-1"><strong>DNI:</strong> @Model.Mujer?.DNI</p>
                <p class="mb-1"><strong>Teléfono:</strong> @Model.Mujer?.Telefono</p>
                <p class="mb-1"><strong>Localidad:</strong> @Model.Mujer?.Localidad</p>

                <div class="mt-3">
                    <a asp-controller="Mujeres" asp-action="Editar" asp-route-id="@Model.MujerID" class="btn btn-sm btn-outline-primary w-100">
                        <i class="bi bi-pencil-square"></i> Editar Datos Personales
                    </a>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 border-top border-success border-4 mb-4">
            <div class="card-body">
                <h5 class="card-title text-success fw-bold"><i class="bi bi-door-closed-fill"></i> Alojamiento</h5>
                <hr />
                @if (Model.Habitacion != null)
                {
                    <h4 class="fw-bold">Habitación @Model.Habitacion.NroHabitacion</h4>
                    <p class="text-muted mb-3">Capacidad de la habitación: @Model.Habitacion.Capacidad plazas</p>
                    <a asp-action="AsignarHabitacion" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-success w-100">
                        <i class="bi bi-arrow-left-right"></i> Cambiar Habitación
                    </a>
                }
                else
                {
                    <div class="alert alert-warning text-dark mb-3">
                        <i class="bi bi-exclamation-triangle-fill"></i> Sin habitación asignada (En tránsito).
                    </div>
                    <a asp-action="AsignarHabitacion" asp-route-id="@Model.Id" class="btn btn-sm btn-success w-100 fw-bold">
                        <i class="bi bi-plus-circle"></i> Asignar Cama Ahora
                    </a>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 border-top border-info border-4 mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="card-title text-info fw-bold mb-0"><i class="bi bi-people-fill"></i> Menores a Cargo</h5>
                                   </div>
                <hr />
                @if (Model.Mujer?.Hijos != null && Model.Mujer.Hijos.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var hijo in Model.Mujer.Hijos)
                        {
                            <li class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold d-block">@hijo.Nombre @hijo.Apellido</span>
                                    <small class="text-muted">DNI: @hijo.DNI</small>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center mb-0 mt-3">No registra menores ingresados.</p>
                }
                <div class="p-2 bg-light border-top text-center">
                    <a asp-controller="Hijos" asp-action="AgregarHijo" asp-route-id="@Model.Mujer.ID" class="btn btn-outline-secondary btn-sm w-100">
                        <i class="bi bi-person-plus"></i> Registrar Menor
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">

        <div class="card shadow-sm border-0 border-top border-danger border-4 mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom-0 pt-3 pb-0">
                <h5 class="card-title text-danger fw-bold mb-0"><i class="bi bi-person-x-fill"></i> Agresores Identificados</h5>
                <a asp-controller="Agresores" asp-action="Alta" asp-route-registroId="@Model.Id" class="btn btn-sm btn-danger fw-bold shadow-sm">
                    <i class="bi bi-plus-circle"></i> Cargar Agresor
                </a>
            </div>
            <div class="card-body">
                <hr class="mt-2" />
                @if (Model.Agresores != null && Model.Agresores.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre Completo</th>
                                    <th>Vínculo</th>
                                    <th>DNI</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var agresor in Model.Agresores)
                                {
                                    <tr>
                                        <td class="fw-bold">@agresor.Apellido, @agresor.Nombre</td>
                                        <td>@agresor.Vinculo</td>
                                        <td>@agresor.DNI</td>                                        
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center p-4 text-muted border rounded bg-light">
                        <i class="bi bi-shield-check fs-2 d-block mb-2 text-secondary"></i>
                        Aún no se han cargado datos de agresores para este expediente.
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 border-top border-warning border-4 mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center border-bottom-0 pt-3 pb-0">
                <h5 class="card-title text-warning fw-bold mb-0 text-dark"><i class="bi bi-file-earmark-text-fill"></i> Denuncias y Medidas</h5>
                <a asp-controller="Denuncias" asp-action="Alta" asp-route-registroId="@Model.Id" class="btn btn-sm btn-warning text-dark fw-bold shadow-sm">
                    <i class="bi bi-plus-circle"></i> Nueva Denuncia
                </a>
            </div>
            <div class="card-body">
                <hr class="mt-2" />

                @if (Model.Denuncias != null && Model.Denuncias.Any())
                {
                    <div class="accordion" id="acordeonDenuncias">
                        @foreach (var denuncia in Model.Denuncias)
                        {
                            <div class="accordion-item mb-2 border rounded">
                                <h2 class="accordion-header" id="heading-@denuncia.ID">
                                    <button class="accordion-button collapsed bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@denuncia.ID">
                                        <strong>Denuncia del @denuncia.Fecha.ToString("dd/MM/yyyy")</strong>
                                        @if (denuncia.NroIPP != null)
                                        {
                                            <span class="badge bg-secondary ms-2">IPP: @denuncia.NroIPP</span>
                                        }
                                    </button>
                                </h2>
                                <div id="collapse-@denuncia.ID" class="accordion-collapse collapse" data-bs-parent="#acordeonDenuncias">
                                    <div class="accordion-body">
                                        <h6 class="fw-bold text-danger border-bottom pb-1 mb-2">Medidas de Protección:</h6>

                                        @if (denuncia.Medida != null && denuncia.Medida.Any())
                                        {
                                            <ul class="list-group list-group-flush mb-3">
                                                @foreach (var medida in denuncia.Medida)
                                                {
                                                    <li class="list-group-item px-0 py-1">
                                                        <i class="bi bi-check2-circle text-success me-2"></i>
                                                        <span class="fw-bold">@(medida.TipoMedida?.Descripcion ?? "Medida no especificada")</span>
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        <div class="text-end">
                                            <a asp-controller="Medidas" asp-action="Alta" asp-route-denunciaId="@denuncia.ID" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-shield-plus"></i> Agregar Medida
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center p-4 text-muted border rounded bg-light border-warning border-opacity-25">
                        <i class="bi bi-cone-striped fs-1 d-block mb-3 text-warning"></i>
                        <h6 class="fw-bold text-dark">Sin Registros</h6>
                        <p class="mb-0 small">Aún no se han cargado denuncias para este expediente.</p>
                    </div>
                }
            </div>
        </div>
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-danger text-white fw-bold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-heart-pulse-fill"></i> Resumen de Condiciones</span>
        
               
                <a asp-controller="Mujeres" asp-action="VerCondicion" asp-route-id="@Model.Mujer.ID" class="btn btn-sm btn-light text-danger fw-bold shadow-sm">
                    Ver Historial Completo
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.Mujer?.Condiciones != null && Model.Mujer.Condiciones.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var condicion in Model.Mujer.Condiciones)
                        {
                            <li class="list-group-item">
                                <span class="fw-bold text-danger">@(condicion.TipoCondicion?.Descripcion ?? "Sin especificar")</span>
                                <br />
                                <small class="text-muted">@(condicion.ObservacionCondicion?.Descripcion ?? "Sin detalles")</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center p-4 text-muted">
                        <i class="bi bi-shield-check fs-2 text-success mb-2 d-block"></i>
                        <p class="mb-0">No se registran condiciones médicas particulares.</p>
                    </div>
                }

                <div class="p-3 bg-light border-top text-center">
            
                    
                    <a asp-controller="Mujeres" asp-action="AgregarCondicion" asp-route-id="@Model.Mujer.ID" class="btn btn-outline-danger btn-sm w-100 fw-bold shadow-sm">
                        <i class="bi bi-plus-circle"></i> Añadir Nueva Condición
                    </a>
            
                </div>
            </div>
        </div>

    </div>
</div>