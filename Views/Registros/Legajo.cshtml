@model TPI_GESTION_HOGAR.Models.Registro

@{
    ViewData["Title"] = "Legajo";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 border-start border-primary border-5 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold text-primary mb-0">Legajo de @Model.Mujer?.Apellido, @Model.Mujer?.Nombre</h3>
                <p class="text-muted mb-0 mt-1">Ingreso: @Model.Fecha.ToString("dd/MM/yyyy")</p>
            </div>
            <div class="d-flex align-items-center">
                <a asp-controller="Registros" asp-action="Detalles" asp-route-id="@Model.Id" class="btn btn-outline-secondary fw-bold">
                    Volver a la Ficha
                </a>
            </div>
        </div>
    </div>

    <h5 class="fw-bold text-secondary mb-3">Historial de Evolución y Novedades</h5>

    <div class="row">
        <div class="col-md-10 offset-md-1">

            @if (Model.Seguimientos != null && Model.Seguimientos.Any())
            {
                foreach (var nota in Model.Seguimientos)
                {
                    <div class="card shadow-sm mb-3 border-0 border-start border-4 border-secondary">
                        <div class="card-header bg-white d-flex justify-content-between py-2">
                            <span class="fw-bold">@nota.Categoria</span>
                            <span class="badge bg-light text-dark border">@nota.FechaHora.ToString("dd/MM/yyyy - HH:mm") hs</span>
                        </div>
                        <div class="card-body py-3">
                            <p class="card-text text-dark mb-0" style="white-space: pre-wrap;">@nota.Descripcion</p>
                        </div>
                        <div class="card-footer bg-light py-1 text-end">
                            <small class="text-muted fw-bold">Firma: @nota.Personal?.Nombre @nota.Personal?.Apellido</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light border text-center text-muted p-5">
                    Aún no hay novedades registradas en el legajo de esta residente.
                </div>
            }

        </div>
    </div>

</div> 