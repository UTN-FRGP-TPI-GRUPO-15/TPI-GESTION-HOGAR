@model TPI_GESTION_HOGAR.Models.Denuncia

@{
    ViewData["Title"] = "Registrar Denuncia";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-warning text-dark fw-bold"><i class="bi bi-file-earmark-text"></i> Cargar Denuncia Judicial</h2>
    <a asp-controller="Registros" asp-action="Detalles" asp-route-id="@ViewBag.RegistroId" class="btn btn-outline-secondary shadow-sm">
        <i class="bi bi-arrow-left"></i> Volver al Expediente
    </a>
</div>

<div class="card shadow-sm border-0 border-top border-warning border-4 col-md-8 mx-auto">
    <div class="card-body p-4">
        <form asp-action="Alta" method="post">
            <input type="hidden" name="RegistroId" value="@ViewBag.RegistroId" />

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Fecha" class="form-label fw-bold">Fecha de la Denuncia</label>
                    <input asp-for="Fecha" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="NroIPP" class="form-label fw-bold">N° de IPP (Investigación Penal Preparatoria)</label>
                    <input asp-for="NroIPP" class="form-control" type="number" placeholder="Opcional" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="NroExp" class="form-label fw-bold">N° de Expediente Judicial</label>
                    <input asp-for="NroExp" class="form-control" type="number" placeholder="Opcional" />
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4 border-top pt-3">
                <button type="submit" class="btn btn-warning text-dark shadow-sm fw-bold px-4">
                    <i class="bi bi-save"></i> Guardar Denuncia
                </button>
            </div>
        </form>
    </div>
</div>