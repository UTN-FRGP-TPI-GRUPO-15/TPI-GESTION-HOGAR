@model IEnumerable<TPI_GESTION_HOGAR.Models.Mujer>

@{
    ViewData["Title"] = "Listado de Residentes";
}

<h2 class="mb-4 text-primary"><i class="bi bi-people-fill"></i> Gestión de Residentes</h2>

<div class="row mb-4 align-items-center">
    <div class="col-md-4">
        <a class="btn btn-primary shadow-sm" asp-action="VerificarDni">
            <i class="bi bi-plus-circle"></i> Nuevo Ingreso
        </a>
    </div>
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex justify-content-end">
            <input type="text" name="buscarTexto" class="form-control w-75 me-2 shadow-sm"
                   placeholder="Buscar por DNI, Nombre o Apellido..."
                   value="@ViewData["FiltroTexto"]">

            <button type="submit" class="btn btn-success shadow-sm">Buscar</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2 shadow-sm">Limpiar</a>
        </form>
    </div>
    
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>DNI</th>
                        <th>Apellido</th>
                        <th>Nombre</th>
                        <th>Edad</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var mujer in Model)
                        {
                            <tr>
                                <td class="fw-bold">@mujer.DNI</td>
                                <td>@mujer.Apellido</td>
                                <td>@mujer.Nombre</td>
                                <td>@mujer.Edad</td>                                                              
                                <td class="text-center">
                                    <a asp-action="Editar" asp-route-id="@mujer.ID" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil-square">Editar</i>
                                    </a>
                                    <a asp-action="Detalles" asp-route-id="@mujer.ID" class="btn btn-sm btn-outline-info" title="Ver Ficha">
                                        <i class="bi bi-eye">Ver Ficha</i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center p-5 text-muted">
                                <h5><i class="bi bi-inbox fs-1"></i></h5>
                                <p class="mb-0">No se encontraron residentes registradas con ese criterio de búsqueda.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>