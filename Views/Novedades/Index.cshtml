@model IEnumerable<TPI_GESTION_HOGAR.Models.Novedad>

@{
    ViewData["Title"] = "Libro de Guardia";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2 border-bottom pb-3 border-info">
    <h2 class="text-info text-dark fw-bold"><i class="bi bi-journal-bookmark-fill"></i> Libro de Novedades y Guardia</h2>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary shadow-sm fw-bold">
        <i class="bi bi-house"></i> Volver al Dashboard
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">

        <div class="card shadow-sm border-0 bg-light mb-4">
            <div class="card-body">
                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-search"></i> Buscar Registros</h6>
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="date" name="fechaBusqueda" class="form-control me-2 border-info shadow-sm" value="@ViewBag.FechaActual" />
                    <button type="submit" class="btn btn-info text-white fw-bold shadow-sm">Ver</button>
                    @if (!string.IsNullOrEmpty(ViewBag.FechaActual))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2"><i class="bi bi-x-circle"></i></a>
                    }
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0 border-top border-info border-4">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <h5 class="fw-bold text-dark"><i class="bi bi-pencil-square text-info"></i> Nuevo Registro</h5>
            </div>
            <div class="card-body pt-0">
                <form asp-action="Crear" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Firma (Personal Activo)</label>
                        <select name="PersonalId" class="form-select border-info shadow-sm" asp-items="@ViewBag.PersonalActivo" required>
                            <option value="">-- Seleccione su nombre --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Detalle del Reporte</label>
                        <textarea name="Descripcion" class="form-control border-info shadow-sm" rows="6" placeholder="Escriba aquí los detalles del turno, traslados, alertas..." required></textarea>
                    </div>

                    <div class="form-check form-switch mb-4 p-3 bg-info bg-opacity-10 border border-info border-opacity-25 rounded">
                        <input class="form-check-input ms-0 me-2" type="checkbox" name="EsPaseDeGuardia" value="true" id="checkPaseGuardia">
                        <label class="form-check-label fw-bold text-dark ms-1" for="checkPaseGuardia">
                            Es Cierre / Pase de Guardia
                        </label>
                    </div>

                    <button type="submit" class="btn btn-info text-white fw-bold shadow-sm w-100 py-2">
                        <i class="bi bi-send"></i> Asentar en el Libro
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success shadow-sm fw-bold"><i class="bi bi-check-circle-fill"></i> @TempData["MensajeExito"]</div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="timeline-container">
                @foreach (var novedad in Model)
                {
                    <div class="card shadow-sm border-0 mb-3 @(novedad.EsPaseDeGuardia ? "border-start border-info border-5" : "")">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center @(novedad.EsPaseDeGuardia ? "border-info border-opacity-25" : "")">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle p-2 me-3 text-center" style="width: 45px; height: 45px;">
                                    <i class="bi @(novedad.EsPaseDeGuardia ? "bi-arrow-left-right text-info" : "bi-person-fill text-secondary") fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">@(novedad.Personal?.Apellido), @(novedad.Personal?.Nombre)</h6>
                                    <small class="text-muted"><i class="bi bi-calendar-event"></i> @novedad.FechaHora.ToString("dddd, dd de MMMM yyyy") - @novedad.FechaHora.ToString("HH:mm") hs</small>
                                </div>
                            </div>
                            @if (novedad.EsPaseDeGuardia)
                            {
                                <span class="badge bg-info text-dark shadow-sm px-3 py-2"><i class="bi bi-journal-check"></i> PASE DE GUARDIA</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="mb-0 text-secondary" style="white-space: pre-wrap; font-size: 1.05rem; line-height: 1.6;">@novedad.Descripcion</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body text-center p-5 text-muted">
                    <i class="bi bi-journal-x display-1 mb-3 text-secondary opacity-50"></i>
                    <h4 class="fw-bold">Libro en Blanco</h4>
                    <p>No se encontraron registros de novedades para la fecha seleccionada.</p>
                </div>
            </div>
        }
    </div>
</div>