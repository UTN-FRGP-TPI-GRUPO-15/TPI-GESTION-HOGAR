<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hogar </title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
    
        :root {
            --violeta-principal: #6f42c1; /* Violeta fuerte */
            --violeta-oscuro: #59339d;
            --lila-claro: #f1eaff;
            --lila-hover: #855ed6;
        }

        body {
            background-color: #f8f9fc;
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* DISEÑO LATERAL (SIDEBAR) */
        #wrapper {
            display: flex;
            width: 100%;
            align-items: stretch;
            min-height: 100vh;
        }

        #sidebar {
            min-width: 260px;
            max-width: 260px;
            background: linear-gradient(180deg, var(--violeta-oscuro) 0%, var(--violeta-principal) 100%);
            color: #fff;
            transition: all 0.3s;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }

            #sidebar .sidebar-header {
                padding: 25px 20px;
                text-align: center;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                background-color: rgba(0,0,0,0.1);
            }

                #sidebar .sidebar-header h6 {
                    font-size: 0.85rem;
                    letter-spacing: 1px;
                    margin-top: 10px;
                    font-weight: 700;
                }

            #sidebar ul.components {
                padding: 20px 0;
            }

            #sidebar ul p {
                color: #fff;
                padding: 10px;
            }

            #sidebar ul li a {
                padding: 12px 20px;
                font-size: 1.05em;
                display: block;
                color: rgba(255,255,255,0.85);
                text-decoration: none;
                border-left: 4px solid transparent;
                transition: 0.2s;
            }

                #sidebar ul li a:hover, #sidebar ul li a.active {
                    color: #fff;
                    background: var(--lila-hover);
                    border-left: 4px solid #fff;
                }

                #sidebar ul li a i {
                    margin-right: 10px;
                    font-size: 1.2rem;
                    vertical-align: middle;
                }

        /* CONTENIDO PRINCIPAL */
        #content {
            width: 100%;
            display: flex;
            flex-direction: column;
        }

        .top-navbar {
            background-color: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            padding: 15px 25px;
        }

        /* ADAPTACIÓN PARA CELULARES */
        @@media (max-width: 768px) {
            #sidebar {
                margin-left: -260px;
                position: fixed;
                height: 100vh;
                z-index: 999;
            }

                #sidebar.active {
                    margin-left: 0;
                }
        }
    </style>
</head>
<body>

    <div id="wrapper">

        <nav id="sidebar">
            <div class="sidebar-header">
                <img src="/images/logo-muni.png" alt="Logo" class="img-fluid mb-2" style="max-height: 70px;" />
                <h6 class="text-uppercase mb-0 mt-2">Hogar de Protección integral de mujeres en situaciones de violencia</h6>
                <div class="fw-bold fs-5"></div>
            </div>

            <ul class="list-unstyled components">

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="px-3 mb-2 mt-2">
                        <small class="text-uppercase text-light opacity-75 fw-bold" style="font-size: 0.75rem;">Operativa Diaria</small>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> Panel de Control
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Novedades" asp-action="Index">
                            <i class="bi bi-journal-bookmark"></i> Libro de Guardia
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Mujeres" asp-action="Index">
                            <i class="bi bi-people"></i> Residentes
                        </a>
                    </li>

                    @if ( User.IsInRole("Equipo Tecnico"))
                    {
                        <li class="px-3 mb-2 mt-4">
                            <small class="text-uppercase text-light opacity-75 fw-bold" style="font-size: 0.75rem;">Administración</small>
                        </li>
                        <li>
                            <a asp-controller="Turnos" asp-action="Index">
                                <i class="bi bi-calendar-check"></i> Gestión de Turnos
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Personal" asp-action="Index">
                                <i class="bi bi-person-badge"></i> Personal
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Reportes" asp-action="Index">
                                <i class="bi bi-bar-chart-line"></i> Reportes
                            </a>
                        </li>
                    }
                }
            </ul>
        </nav>

        <div id="content">

            <nav class="top-navbar d-flex justify-content-between align-items-center">
                <button type="button" id="sidebarCollapse" class="btn btn-outline-secondary d-md-none border-0">
                    <i class="bi bi-list fs-3"></i>
                </button>

                <div class="ms-auto d-flex align-items-center">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="text-muted fw-bold me-3">
                            <i class="bi bi-person-circle fs-5 me-1 text-primary" style="vertical-align: text-bottom; color: var(--violeta-principal) !important;"></i>
                            Hola, @User.Identity.Name
                        </div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm fw-bold">
                                <i class="bi bi-box-arrow-right"></i> Salir
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-primary shadow-sm" style="background-color: var(--violeta-principal); border: none;" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                    }
                </div>
            </nav>

            <main role="main" class="p-4 flex-grow-1">

                @if (TempData["MensajeExito"] != null)
                {
                    <div class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index:1055;">
                        <div class="alert alert-success alert-dismissible fade show shadow border-0 border-start border-success border-4" role="alert">
                            <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["MensajeExito"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    </div>
                }

                @if (TempData["MensajeError"] != null)
                {
                    <div class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index:1055;">
                        <div class="alert alert-danger alert-dismissible fade show shadow border-0 border-start border-danger border-4 d-flex align-items-start gap-2" role="alert">
                            <i class="bi bi-exclamation-triangle-fill text-danger mt-1"></i>
                            <div>
                                @Html.Raw(TempData["MensajeError"])
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    </div>
                }

                @RenderBody()

            </main>

            <footer class="text-center text-muted py-3 bg-white border-top mt-auto small">
                &copy; @DateTime.Now.Year - Hogar de Protección Integral 
            </footer>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            // menú lateral para celulares
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });

            
            setTimeout(function () {
                       let alert = document.querySelector('.alert-dismissible');
            if (alert) {
                let bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        }, 4000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>