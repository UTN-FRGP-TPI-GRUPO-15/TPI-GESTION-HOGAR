@model TPI_GESTION_HOGAR.Models.Personal

<h1 class="mb-4 text-center">Editar Personal</h1>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <form asp-action="Edit" method="POST">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold alert alert-warning"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Activo" />
                <input type="hidden" asp-for="Usuario" />

                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Datos de Personal</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Legajo" class="form-label"></label>
                                <input asp-for="Legajo" type="number" placeholder="1264" class="form-control" readonly />
                                <span asp-validation-for="Legajo" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DNI" class="form-label"></label>
                                <input asp-for="DNI" type="text" placeholder="37482483" class="form-control" required pattern="\d+" />
                                <span asp-validation-for="DNI" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label"></label>
                                <input asp-for="Nombre" type="text" placeholder="María" class="form-control" required />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellido" class="form-label"></label>
                                <input asp-for="Apellido" type="text" placeholder="Pérez" class="form-control" required />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nacionalidad" class="form-label"></label>
                                <input asp-for="Nacionalidad" type="text" placeholder="Argentina" class="form-control" required />
                                <span asp-validation-for="Nacionalidad" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaNac" class="form-label">Fecha de nacimiento</label>
                                <input asp-for="FechaNac" type="date" class="form-control" required />
                                <span asp-validation-for="FechaNac" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Provincia" class="form-label">Provincia</label>
                                <select class="form-select" id="Provincia" name="Provincia" required>
                                    <option value="">Seleccione una provincia...</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Localidad" class="form-label">Localidad</label>
                                <select asp-for="Localidad" class="form-control" id="Localidad" name="Localidad" required disabled>
                                    <option value="">Seleccione una provincia primero...</option>
                                </select>
                                <span asp-validation-for="Localidad" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Domicilio" class="form-label"></label>
                                <input asp-for="Domicilio" type="text" placeholder="Belgrano 291" class="form-control" />
                                <span asp-validation-for="Domicilio" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label">Teléfono</label>
                                <input asp-for="Telefono" type="text" placeholder="+5411283847" class="form-control" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>                              
                
                <button type="submit" class="btn btn-primary">Guardar cambios</button>

                @if (ViewBag.Message != null)
                {
                    <div class="mt-3" style="color:@(ViewBag.IsError ? "red" : "green")">
                        @ViewBag.Message
                    </div>
                }
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const selectProvincia = document.getElementById("Provincia");
            const selectLocalidad = document.getElementById("Localidad");

            // 1. Apenas carga la página, buscamos las provincias
            fetch("https://apis.datos.gob.ar/georef/api/provincias?campos=id,nombre&orden=nombre")
                .then(response => response.json())
                .then(data => {
                    data.provincias.forEach(prov => {
                        let option = document.createElement("option");
                        // Guardamos el nombre como "value" para que viaje a tu base de datos
                        option.value = prov.nombre;
                        option.textContent = prov.nombre;
                        // Guardamos el ID oculto para usarlo en la búsqueda de localidades
                        option.dataset.id = prov.id;
                        selectProvincia.appendChild(option);
                    });
                })
                .catch(error => console.error("Error al cargar provincias:", error));

            // 2. Cuando el usuario cambia la provincia, buscamos sus localidades
            selectProvincia.addEventListener("change", function () {
                // Limpiamos el combo de localidades y ponemos mensaje de carga
                selectLocalidad.innerHTML = '<option value="">Cargando localidades...</option>';
                selectLocalidad.disabled = true;

                // Obtenemos el ID de la provincia seleccionada
                const selectedOption = this.options[this.selectedIndex];
                const provId = selectedOption.dataset.id;

                if (!provId) {
                    selectLocalidad.innerHTML = '<option value="">Seleccione una provincia primero...</option>';
                    return;
                }

                // Llamamos a la API pidiendo las localidades de esa provincia (max=1000 para que traiga todas)
                fetch(`https://apis.datos.gob.ar/georef/api/localidades?provincia=${provId}&campos=id,nombre&max=1000&orden=nombre`)
                    .then(response => response.json())
                    .then(data => {
                        selectLocalidad.innerHTML = '<option value="">Seleccione una localidad...</option>';
                        data.localidades.forEach(loc => {
                            let option = document.createElement("option");
                            option.value = loc.nombre;
                            option.textContent = loc.nombre;
                            selectLocalidad.appendChild(option);
                        });
                        // Habilitamos el combo para que la usuaria pueda elegir
                        selectLocalidad.disabled = false;
                    })
                    .catch(error => {
                        console.error("Error al cargar localidades:", error);
                        selectLocalidad.innerHTML = '<option value="">Error al cargar localidades</option>';
                    });
            });
        });
    </script>
}