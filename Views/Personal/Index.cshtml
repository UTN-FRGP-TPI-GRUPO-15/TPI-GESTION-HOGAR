@using TPI_GESTION_HOGAR.Models
@using static System.Runtime.InteropServices.JavaScript.JSType
@model IEnumerable<Personal>

<h2 class="mb-4 text-primary"><i class="bi bi-people-fill"></i>Gestión de Personal</h2>

<div class="row mb-4 align-items-center">
	<div class="col-md-4">
		<a class="btn btn-primary shadow-sm" href="/Personal/Alta">
			<i class="bi bi-plus-circle"></i>Nuevo Personal
		</a>
	</div>
	<div class="col-md-8">
		<form asp-action="Index" method="get" class="d-flex justify-content-end">
			<input type="text" name="searchString" class="form-control w-75 me-2 shadow-sm"
				placeholder="Buscar por Legajo, Nombre o Apellido..."
				value="@ViewData["CurrentFilter"]">
			
			<button type="submit" class="btn btn-success shadow-sm">Buscar</button>
			<a asp-action="Index" class="btn btn-outline-secondary ms-2 shadow-sm">Limpiar</a>
		</form>
	</div>
</div>

<div class="card shadow-sm border-0">
	<div class="card-body p-0">
		<div class="table-responsive">
			<table class="table table-hover table-striped mb-0">
				<thead class="table-dark">
					<tr>
						<th>Legajo</th>
						<th><a class="text-light" asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]"><label>Nombre</label></a></th>
						<th><a class="text-light" asp-action="Index" asp-route-sortOrder="@ViewData["LastNameSortParm"]"><label>Apellido</label></a></th>
						<th>Estado</th>
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					@if (Model != null && Model.Any())
					{
						foreach (var personal in Model)
						{
							<tr>
								<td class="fw-bold">@personal.Legajo</td>
								<td>@personal.Nombre</td>
								<td>@personal.Apellido</td>	
								@if (personal.Activo)
								{
									<td class="fw-bold">Activo</td>
								}
								else
								{
									<td class="fw-bold">Inactivo</td>
								}
								<td class="text-center">
									<a asp-action="Edit" asp-route-id="@personal.Id" class="btn btn-sm btn-outline-primary" title="Editar">
										<i class="bi bi-pencil-square">Editar</i>
									</a>
									@if (personal.Activo)
									{
										<a asp-action="AltaBaja" asp-route-id="@personal.Id" class="btn btn-sm btn-outline-warning" title="Dar de Baja">
											<i class="bi bi-eye">Desactivar</i>
										</a>					
									}
									else
									{
										<a asp-action="AltaBaja" asp-route-id="@personal.Id" class="btn btn-sm btn-outline-success" title="Dar de Alta">
											<i class="bi bi-eye">Activar</i>
										</a>
									}
									<a asp-action="Delete" asp-route-id="@personal.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
										<i class="bi bi-eye">Eliminar</i>
									</a>
									<a asp-action="Detalles" asp-route-id="@personal.Id" class="btn btn-sm btn-outline-info" title="Ver Ficha">
										<i class="bi bi-eye">Ver Ficha</i>
									</a>
								</td>
							</tr>
						}
					}
					else
					{
						<tr>
							<td colspan="5" class="text-center p-5 text-muted">
								<h5><i class="bi bi-inbox fs-1"></i></h5>
								<p class="mb-0">No se encontró personal registrado con ese criterio de búsqueda.</p>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
</div>